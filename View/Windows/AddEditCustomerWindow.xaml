<Window x:Class="Bookmaster34.View.Windows.AddEditCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bookmaster34.View.Windows"
        mc:Ignorable="d"
            Title="Окно авторизации клиента" SizeToContent="Height" Width="900" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20 20 20 20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="410"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="410"/>

        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ID:"/>
            <TextBox Name="IDclientTb" Grid.Column="2" IsReadOnly="True"  Width="200" HorizontalAlignment="Left" />

            <TextBlock Text="Имя клиента:" Grid.Row="2"/>
            <TextBox Name="ClientNameTb" Grid.Column="2" Grid.Row="2" Width="200" HorizontalAlignment="Left" Text="{Binding Name}"/>

            <TextBlock Text="Адрес клиента:" Grid.Row="4"/>
            <TextBox Name="AddressClientTb" Grid.Column="2" Grid.Row="4" Width="200" HorizontalAlignment="Left" Text="{Binding Address}"/>

            <TextBlock Text="Индекс/город:" Grid.Row="6"/>
            <TextBox Name="ZipCityTb" Grid.Column="1" Grid.Row="6" TextChanged="ZipCityTb_TextChanged" Margin="20,0,156,0" Grid.ColumnSpan="2" Text="{Binding Zip}"/>
            <ComboBox Name="ZipCityCb" Width="140" SelectionChanged="ZipCityCb_SelectionChanged" Grid.Column="2" Grid.Row="6" HorizontalAlignment="Right" SelectedIndex="0" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        </Grid>

        <Grid Grid.Column="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Телефон:" Grid.Row="1"/>
            <TextBox Name="PhoneCustomerTb" Grid.Column="2" Grid.Row="1" Width="200" HorizontalAlignment="Left" Text="{Binding Phone}"/>

            <TextBlock Text="Электронная почта:" Grid.Row="3"/>
            <TextBox Name="EmailCustomerTb" Grid.Column="2" Grid.Row="3" Width="200" HorizontalAlignment="Left" Text="{Binding Email}"/>

            <Grid Grid.Row="5" Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Button Name="EditBtn" Content="Редактировать" Click="EditBtn_Click"  Width="100" HorizontalAlignment="Center" Height="50" VerticalAlignment="Top" />
                <Button Name="AddBtn" Content="Добавить" Click="AddBtn_Click"  Width="100" HorizontalAlignment="Center" Height="50" VerticalAlignment="Top"/>
                <Button Name="CancelBtn" Grid.Column="2" Content="Отмена" Width="100" HorizontalAlignment="Right" Click="CancelBtn_Click"  Cursor="Hand"/>

            </Grid>
        </Grid>

    </Grid>
</Window>
